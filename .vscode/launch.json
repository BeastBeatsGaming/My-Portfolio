{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Brave with Python Server",
            "url": "http://localhost:8000",
            "webRoot": "${workspaceFolder}",
            "runtimeExecutable": "${env:LOCALAPPDATA}\\BraveSoftware\\Brave-Browser\\Application\\brave.exe",
            "runtimeArgs": [
                "--remote-debugging-port=9222",
                "--user-data-dir=${workspaceFolder}/.vscode/brave-debug-profile",
                "--disable-background-timer-throttling",
                "--disable-renderer-backgrounding"
            ],
            "preLaunchTask": "Start Python Server",
            "serverReadyAction": {
                "pattern": "Serving HTTP on .* port ([0-9]+)",
                "uriFormat": "http://localhost:%s",
                "action": "openExternally"
            }
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Chrome with Python Server",
            "url": "http://localhost:8000",
            "webRoot": "${workspaceFolder}",
            "preLaunchTask": "Start Python Server",
            "serverReadyAction": {
                "pattern": "Serving HTTP on .* port ([0-9]+)",
                "uriFormat": "http://localhost:%s",
                "action": "openExternally"
            }
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Brave Browser (Direct File)",
            "file": "${workspaceFolder}/index.html",
            "webRoot": "${workspaceFolder}",
            "runtimeExecutable": "${env:LOCALAPPDATA}\\BraveSoftware\\Brave-Browser\\Application\\brave.exe",
            "runtimeArgs": [
                "--remote-debugging-port=9222",
                "--user-data-dir=${workspaceFolder}/.vscode/brave-debug-profile",
                "--allow-file-access-from-files"
            ]
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Chrome (Direct File)",
            "file": "${workspaceFolder}/index.html",
            "webRoot": "${workspaceFolder}",
            "runtimeArgs": [
                "--allow-file-access-from-files"
            ]
        },
        {
            "type": "msedge",
            "request": "launch",
            "name": "Launch Edge with Python Server",
            "url": "http://localhost:8000",
            "webRoot": "${workspaceFolder}",
            "preLaunchTask": "Start Python Server"
        }
    ]
}